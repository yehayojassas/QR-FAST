# Copie ce fichier en ".env" (jamais commité, voir .gitignore) et remplis les vraies valeurs.

# Connexion à la base Supabase (Project Settings -> Database -> Connection string -> URI)
DATABASE_URL=

# Code PIN de l'équipe (protège accepter/refuser/statut table côté /staff)
STAFF_PIN=

# Code PIN du propriétaire (fait tout ce que fait STAFF_PIN + accès aux avis
# clients ; si vide, cette distinction de rôle n'existe pas)
OWNER_PIN=
